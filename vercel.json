{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/blog.html", "destination": "/en/blog/", "permanent": true },
    { "source": "/blog-hr.html", "destination": "/blog/", "permanent": true },
    { "source": "/blog-hr", "destination": "/blog/", "permanent": true },
    { "source": "/blog-hr/", "destination": "/blog/", "permanent": true },
    { "source": "/blog/:slug(.+)-hr.html", "destination": "/blog/:slug/", "permanent": true },
    { "source": "/blog/:slug(.+)-hr", "destination": "/blog/:slug/", "permanent": true },
    { "source": "/blog/:slug(.+)-hr/", "destination": "/blog/:slug/", "permanent": true },
    { "source": "/blog/:slug.html", "destination": "/en/blog/:slug/", "permanent": true },
    { "source": "/assessment.html", "destination": "/en/assessment/", "permanent": true },
    { "source": "/privacy.html", "destination": "/en/privacy/", "permanent": true },
    { "source": "/privacy-hr.html", "destination": "/privacy/", "permanent": true },
    { "source": "/privacy-hr", "destination": "/privacy/", "permanent": true },
    { "source": "/privacy-hr/", "destination": "/privacy/", "permanent": true },
    { "source": "/imprint.html", "destination": "/en/imprint/", "permanent": true },
    { "source": "/imprint-hr.html", "destination": "/imprint/", "permanent": true },
    { "source": "/imprint-hr", "destination": "/imprint/", "permanent": true },
    { "source": "/imprint-hr/", "destination": "/imprint/", "permanent": true },
    { "source": "/colophon", "destination": "/", "permanent": true },
    { "source": "/colophon/", "destination": "/", "permanent": true },
    { "source": "/en/colophon", "destination": "/en/", "permanent": true },
    { "source": "/en/colophon/", "destination": "/en/", "permanent": true },
    { "source": "/colophon.html", "destination": "/en/", "permanent": true },
    { "source": "/colophon-hr.html", "destination": "/", "permanent": true },
    { "source": "/colophon-hr", "destination": "/", "permanent": true },
    { "source": "/colophon-hr/", "destination": "/", "permanent": true },
    { "source": "/hr", "destination": "/", "permanent": true },
    { "source": "/hr/", "destination": "/", "permanent": true },
    { "source": "/hr/blog", "destination": "/blog/", "permanent": true },
    { "source": "/hr/blog/", "destination": "/blog/", "permanent": true },
    { "source": "/hr/blog/:slug", "destination": "/blog/:slug/", "permanent": true },
    { "source": "/hr/blog/:slug/", "destination": "/blog/:slug/", "permanent": true },
    { "source": "/hr/assessment", "destination": "/assessment/", "permanent": true },
    { "source": "/hr/assessment/", "destination": "/assessment/", "permanent": true },
    { "source": "/hr/privacy", "destination": "/privacy/", "permanent": true },
    { "source": "/hr/privacy/", "destination": "/privacy/", "permanent": true },
    { "source": "/hr/imprint", "destination": "/imprint/", "permanent": true },
    { "source": "/hr/imprint/", "destination": "/imprint/", "permanent": true },
    { "source": "/hr/colophon", "destination": "/", "permanent": true },
    { "source": "/hr/colophon/", "destination": "/", "permanent": true },

    { "source": "/sitemap.xml", "destination": "/sitemap-index.xml", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-site" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://www.googletagmanager.com https://www.clarity.ms https://*.clarity.ms https://www.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://formspree.io https://api.github.com https://github.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://www.clarity.ms https://*.clarity.ms https://www.google.com; frame-src https://www.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://formspree.io https://github.com" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
