---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/LegalPage.astro";
import { SITE } from "../lib/i18n";
const lang = "hr" as const;
---
<BaseLayout
  lang={lang}
  title="Politika privatnosti | Danijel Pevec"
  description="Politika privatnosti — Danijel Pevec, savjetnik za obiteljski biznis."
  canonical={`${SITE}/privacy/`}
  hreflangEn={`${SITE}/privacy/`}
  hreflangHr={`${SITE}/privacy/`}
>
  <LegalPage lang={lang} title="Politika privatnosti">
    <p class="lead">Detaljna politika privatnosti je u pripremi. Do tada, svaki razgovor pokrenut putem ove stranice tretira se u strogoj povjerljivosti.</p>
    <p class="lead" style="margin-top:24px;">Do objave potpune politike, možete nas kontaktirati na <a href="mailto:pevec.danijel@alphacapitalis.com">pevec.danijel@alphacapitalis.com</a>.</p>
  </LegalPage>
</BaseLayout>
