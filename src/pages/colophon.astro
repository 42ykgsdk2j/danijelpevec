---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/LegalPage.astro";
import { SITE } from "../lib/i18n";
const lang = "en" as const;
---
<BaseLayout
  lang={lang}
  title="Colophon | Danijel Pevec"
  description="Colophon — about the type, typography and craft of danijelpevec.com."
  canonical={`${SITE}/colophon/`}
  hreflangEn={`${SITE}/colophon/`}
  hreflangHr={`${SITE}/hr/colophon/`}
>
  <LegalPage lang={lang} eyebrow="Colophon" title="Colophon">
    <p class="lead">This site is set in Playfair Display and Inter. Words are chosen as carefully as the type that carries them.</p>
    <p class="lead" style="margin-top:24px;">Quietly built. Long-form by intent.</p>
  </LegalPage>
</BaseLayout>
