---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/LegalPage.astro";
import { SITE } from "../lib/i18n";
const lang = "hr" as const;
---
<BaseLayout
  lang={lang}
  title="Impressum | Danijel Pevec"
  description="Impressum — Danijel Pevec, savjetnik za obiteljski biznis."
  canonical={`${SITE}/imprint/`}
  hreflangEn={`${SITE}/imprint/`}
  hreflangHr={`${SITE}/imprint/`}
>
  <LegalPage lang={lang} eyebrow="Impressum" title="Impressum">
    <p class="lead">Danijel Pevec — savjetnik za obiteljski biznis.</p>
    <p class="lead" style="margin-top:24px;">Sa sjedištem u Zagrebu, Hrvatska. Samo po dogovoru. Suradnja s Alpha Capitalis.</p>
    <p class="lead" style="margin-top:24px;">Za upite: <a href="mailto:inquiry@danijelpevec.com">inquiry@danijelpevec.com</a>.</p>
  </LegalPage>
</BaseLayout>
