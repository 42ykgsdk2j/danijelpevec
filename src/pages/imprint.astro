---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/LegalPage.astro";
import { SITE } from "../lib/i18n";
const lang = "hr" as const;
---
<BaseLayout
  lang={lang}
  title="Impressum | Danijel Pevec"
  description="Impressum — Danijel Pevec, savjetnik za obiteljski biznis."
  canonical={`${SITE}/imprint/`}
  hreflangEn={`${SITE}/en/imprint/`}
  hreflangHr={`${SITE}/imprint/`}
>
  <LegalPage lang={lang} eyebrow="Impressum" title="Impressum">
    <p class="lead">Danijel Pevec — savjetnik za obiteljski biznis. Privatna savjetodavna praksa po pozivu, fokusirana na osnivače obiteljskih tvrtki i njihove obitelji.</p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Pružatelj usluge</h2>
    <p class="lead" style="margin-top:0;">Danijel Pevec<br />Ulica Roberta Frangeša - Mihanovića 9<br />10110 Zagreb, Hrvatska</p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Kontakt</h2>
    <p class="lead" style="margin-top:0;">E-pošta: <a href="mailto:pevec.danijel@alphacapitalis.com">pevec.danijel@alphacapitalis.com</a></p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Suradnja</h2>
    <p class="lead" style="margin-top:0;">Profesionalno surađujem s društvom <a href="https://www.alphacapitalis.com" target="_blank" rel="noopener noreferrer">ALPHA CAPITALIS</a>, koje pruža usluge financija, poreza, revizije i savjetovanja, a moja se uloga odnosi na strateški i obiteljski dio rada s klijentima.</p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Odgovornost za sadržaj</h2>
    <p class="lead" style="margin-top:0;">Sadržaj ove stranice pripremljen je s pažnjom, no ne predstavlja pravni, porezni ili financijski savjet i ne može zamijeniti razgovor primijenjen na konkretne okolnosti. Vanjske poveznice nisu pod mojim nadzorom i ne odgovaram za njihov sadržaj.</p>
  </LegalPage>
</BaseLayout>
