---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/LegalPage.astro";
import { SITE } from "../lib/i18n";
const lang = "hr" as const;
---
<BaseLayout
  lang={lang}
  title="Impressum | Danijel Pevec"
  description="Impressum — Danijel Pevec, savjetnik za obiteljski biznis."
  canonical={`${SITE}/imprint/`}
  hreflangEn={`${SITE}/en/imprint/`}
  hreflangHr={`${SITE}/imprint/`}
>
  <LegalPage lang={lang} eyebrow="Impressum" title="Impressum">
    <p class="lead">Danijel Pevec — savjetnik za obiteljski biznis. Privatna savjetodavna praksa po pozivu, fokusirana na osnivače obiteljskih tvrtki i njihove obitelji.</p>

    <h2 class="legal-h2">Pružatelj usluge</h2>
    <p class="lead">Danijel Pevec<br />Ulica Roberta Frangeša - Mihanovića 9<br />10110 Zagreb, Hrvatska</p>

    <h2 class="legal-h2">Kontakt</h2>
    <p class="lead">E-pošta: <a href="mailto:pevec.danijel@alphacapitalis.com">pevec.danijel@alphacapitalis.com</a></p>
  </LegalPage>
</BaseLayout>
