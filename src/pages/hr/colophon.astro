---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegalPage from "../../components/LegalPage.astro";
import { SITE } from "../../lib/i18n";
const lang = "hr" as const;
---
<BaseLayout
  lang={lang}
  title="Kolofon | Danijel Pevec"
  description="Kolofon — o tipografiji i izradi danijelpevec.com."
  canonical={`${SITE}/hr/colophon/`}
  hreflangEn={`${SITE}/colophon/`}
  hreflangHr={`${SITE}/hr/colophon/`}
>
  <LegalPage lang={lang} eyebrow="Kolofon" title="Kolofon">
    <p class="lead">Ova stranica koristi fontove Playfair Display i Inter. Riječi su odabrane jednako pažljivo kao i tipografija koja ih nosi.</p>
    <p class="lead" style="margin-top:24px;">Tiho izgrađeno. Dugotrajno po namjeri.</p>
  </LegalPage>
</BaseLayout>
