---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegalPage from "../../components/LegalPage.astro";
import { SITE } from "../../lib/i18n";
const lang = "en" as const;
---
<BaseLayout
  lang={lang}
  title="Privacy Policy | Danijel Pevec"
  description="Privacy policy — how personal data of visitors to this website is processed and what your rights are."
  canonical={`${SITE}/en/privacy/`}
  hreflangEn={`${SITE}/en/privacy/`}
  hreflangHr={`${SITE}/privacy/`}
>
  <LegalPage lang={lang} eyebrow="Privacy" title="Privacy Policy">
    <p class="lead">This policy describes how the personal data of visitors to this website is processed.</p>

    <h2 class="legal-h2">Controller</h2>
    <p class="lead">Danijel Pevec<br />Ulica Roberta Frangeša - Mihanovića 9, 10110 Zagreb, Croatia<br />Email: <a href="mailto:pevec.danijel@alphacapitalis.com">pevec.danijel@alphacapitalis.com</a></p>

    <h2 class="legal-h2">Data we collect</h2>
    <ul class="legal-ul">
      <li>Information submitted via the contact form (name, email, optional fields, and the message itself).</li>
      <li>Technical logs generated automatically (IP address, browser type, timestamp).</li>
      <li>Analytics information about how the site is used — only with your consent.</li>
    </ul>

    <h2 class="legal-h2">Purposes of processing</h2>
    <ul class="legal-ul">
      <li>Responding to enquiries submitted through the form.</li>
      <li>Site security, troubleshooting, and ensuring functionality.</li>
      <li>Measuring traffic and improving the visitor experience.</li>
    </ul>

    <h2 class="legal-h2">Lawful basis</h2>
    <p class="lead">Processing relies on consent, legitimate interest, or contract performance — depending on the type of data and the purpose.</p>

    <h2 class="legal-h2">Recipients</h2>
    <p class="lead">Data may be shared with service providers that support the site (hosting, email delivery, analytics). Data is not sold to third parties.</p>

    <h2 class="legal-h2">International transfers</h2>
    <p class="lead">Some service providers are based outside the European Economic Area. In such cases transfers rely on the European Commission's Standard Contractual Clauses and appropriate additional safeguards.</p>

    <h2 class="legal-h2">Retention</h2>
    <p class="lead">Data is retained only for as long as necessary for the stated purposes or as required by law.</p>

    <h2 class="legal-h2">Cookies</h2>
    <p class="lead">The site uses a minimum of necessary cookies plus optional analytics cookies that load only after your consent. You can change your decision at any time:</p>
    <p class="lead"><button type="button" class="btn btn-ghost" data-consent-reset>Change cookie preferences</button></p>

    <h2 class="legal-h2">Your rights</h2>
    <p class="lead">You have the right to access, rectification, erasure, restriction of processing, data portability, objection, and withdrawal of consent at any time. Requests can be sent to the email address above.</p>

    <h2 class="legal-h2">Right to lodge a complaint</h2>
    <p class="lead">You have the right to lodge a complaint with the Croatian supervisory authority (<a href="https://www.azop.hr" target="_blank" rel="noopener noreferrer">azop.hr</a>).</p>

    <h2 class="legal-h2">Changes</h2>
    <p class="lead">This policy may be updated occasionally. The date of the last revision is shown at the bottom.</p>

    <p class="lead" style="margin-top:32px; color: var(--ink-3);">Last updated: May 2026.</p>
  </LegalPage>

  <script is:inline>
    document.querySelectorAll("[data-consent-reset]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        try { localStorage.removeItem("dp_consent_v1"); } catch (e) {}
        location.reload();
      });
    });
  </script>
</BaseLayout>
