---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import WhoSection from "../../components/WhoSection.astro";
import ChallengesSection from "../../components/ChallengesSection.astro";
import AssessmentCtaSection from "../../components/AssessmentCtaSection.astro";
import ApproachSection from "../../components/ApproachSection.astro";
import WorkSection from "../../components/WorkSection.astro";
import BlogSection from "../../components/BlogSection.astro";
import AboutSection from "../../components/AboutSection.astro";
import FinalCta from "../../components/FinalCta.astro";
import { SITE } from "../../lib/i18n";

const lang = "en" as const;
---
<BaseLayout
  lang={lang}
  title="Danijel Pevec — Trusted Compass for Founders & Family Businesses"
  description="I help founders and their families build a legacy through the decisions that shape growth, succession and generational transition."
  canonical={`${SITE}/en/`}
  hreflangEn={`${SITE}/en/`}
  hreflangHr={`${SITE}/`}
>
  <Hero lang={lang} />
  <WhoSection lang={lang} />
  <ChallengesSection lang={lang} />
  <ApproachSection lang={lang} />
  <WorkSection lang={lang} />
  <AssessmentCtaSection lang={lang} />
  <BlogSection lang={lang} />
  <AboutSection lang={lang} />
  <FinalCta lang={lang} />
</BaseLayout>
