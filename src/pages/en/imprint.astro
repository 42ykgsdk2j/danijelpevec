---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegalPage from "../../components/LegalPage.astro";
import { SITE } from "../../lib/i18n";
const lang = "en" as const;
---
<BaseLayout
  lang={lang}
  title="Imprint | Danijel Pevec"
  description="Imprint — Danijel Pevec, Family Business Advisor."
  canonical={`${SITE}/imprint/`}
  hreflangEn={`${SITE}/imprint/`}
  hreflangHr={`${SITE}/imprint/`}
>
  <LegalPage lang={lang} eyebrow="Imprint" title="Imprint">
    <p class="lead">Danijel Pevec — Family Business Advisor.</p>
    <p class="lead" style="margin-top:24px;">Based in Zagreb, Croatia. By appointment only. Affiliated with ALPHA CAPITALIS.</p>
    <p class="lead" style="margin-top:24px;">For inquiries: <a href="mailto:pevec.danijel@alphacapitalis.com">pevec.danijel@alphacapitalis.com</a>.</p>
  </LegalPage>
</BaseLayout>
