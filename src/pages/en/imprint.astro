---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegalPage from "../../components/LegalPage.astro";
import { SITE } from "../../lib/i18n";
const lang = "en" as const;
---
<BaseLayout
  lang={lang}
  title="Imprint | Danijel Pevec"
  description="Imprint — Danijel Pevec, Family Business Advisor."
  canonical={`${SITE}/en/imprint/`}
  hreflangEn={`${SITE}/en/imprint/`}
  hreflangHr={`${SITE}/imprint/`}
>
  <LegalPage lang={lang} eyebrow="Imprint" title="Imprint">
    <p class="lead">Danijel Pevec — Family Business Advisor. Private advisory practice by appointment, focused on founders of family-owned businesses and their families.</p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Service provider</h2>
    <p class="lead" style="margin-top:0;">Danijel Pevec<br />Ulica Roberta Frangeša - Mihanovića 9<br />10110 Zagreb, Croatia</p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Contact</h2>
    <p class="lead" style="margin-top:0;">Email: <a href="mailto:pevec.danijel@alphacapitalis.com">pevec.danijel@alphacapitalis.com</a></p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Affiliation</h2>
    <p class="lead" style="margin-top:0;">I work professionally in cooperation with <a href="https://www.alphacapitalis.com" target="_blank" rel="noopener noreferrer">ALPHA CAPITALIS</a>, which provides finance, tax, audit, and advisory services. My own role focuses on the strategic and family dimensions of the work.</p>

    <h2 style="font-family: var(--serif); font-size: clamp(20px, 1.8vw, 26px); font-weight: 400; margin-top: 36px; margin-bottom: 12px;">Content disclaimer</h2>
    <p class="lead" style="margin-top:0;">The content of this site is prepared with care but does not constitute legal, tax, or financial advice, and cannot replace a conversation applied to a specific situation. External links are not under my control and I take no responsibility for their content.</p>
  </LegalPage>
</BaseLayout>
