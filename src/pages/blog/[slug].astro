---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getT, url, SITE } from "../../lib/i18n";
import { langOf, slugOf } from "../../content.config";

export async function getStaticPaths() {
  const posts = await getCollection("blog", (entry) => langOf(entry.id) === "hr");
  return posts.map((p) => ({ params: { slug: slugOf(p.id) }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = "hr" as const;
const t = getT(lang);
const slug = slugOf(post.id);
const enUrl = `${SITE}/en/blog/${slug}/`;
const hrUrl = `${SITE}/blog/${slug}/`;
function fmtDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString("hr-HR", { year: "numeric", month: "short", day: "numeric" });
}
const allInsightsLabel = t.blog.viewAll;
---
<BaseLayout
  lang={lang}
  title={`${post.data.title} | Danijel Pevec`}
  description={post.data.excerpt}
  canonical={hrUrl}
  hreflangEn={enUrl}
  hreflangHr={hrUrl}
  ogType="article"
  jsonLd={[{
    "@context": "https://schema.org",
    "@type": "Article",
    headline: post.data.title,
    description: post.data.excerpt,
    author: { "@type": "Person", name: "Danijel Pevec", url: SITE },
    publisher: { "@type": "Person", name: "Danijel Pevec" },
    datePublished: post.data.date,
    dateModified: post.data.date,
    mainEntityOfPage: hrUrl,
    articleSection: post.data.category,
    inLanguage: "hr",
  }]}
>
  <header class="article-header reveal in">
    <div class="container">
      <a href={url(lang, "blog")} class="blog-back"><span class="arr">→</span> {allInsightsLabel}</a>
      <div class="article-meta-row">
        <span class="cat">{post.data.category}</span>
        <span class="dot">·</span>
        <time class="article-date" datetime={post.data.date}>{fmtDate(post.data.date)}</time>
        <span class="dot">·</span>
        <span class="readtime">{post.data.readTime} {t.blog.minRead}</span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-deck">{post.data.excerpt}</p>
      <div class="article-byline"><span class="author-mono">DP</span><span class="who">Autor: <strong>Danijel Pevec</strong> · Savjetnik za obiteljski biznis</span></div>
    </div>
  </header>
  {post.data.cover && (
    <figure class="article-cover">
      <div class="container">
        <img src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} loading="lazy" />
      </div>
    </figure>
  )}
  <article class="article-body">
    <div class="container">
      <Content />
    </div>
  </article>
</BaseLayout>
