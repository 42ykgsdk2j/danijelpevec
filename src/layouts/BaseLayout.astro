---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Modal from "../components/Modal.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import "../styles/global.css";

interface Props {
  lang: "en" | "hr";
  title: string;
  description: string;
  canonical: string; // absolute URL for this page
  hreflangEn?: string; // absolute URL for EN counterpart
  hreflangHr?: string; // absolute URL for HR counterpart
  ogType?: "website" | "article";
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string; // absolute URL
  twitterTitle?: string;
  twitterDescription?: string;
  /* Page-specific structured data, rendered as <script type="application/ld+json"> tags */
  jsonLd?: Record<string, unknown>[];
}

const {
  lang,
  title,
  description,
  canonical,
  hreflangEn,
  hreflangHr,
  ogType = "website",
  ogTitle,
  ogDescription,
  ogImage = "https://www.danijelpevec.com/og-image.png",
  twitterTitle,
  twitterDescription,
  jsonLd = [],
} = Astro.props;

const siteName = "Danijel Pevec";
// reCAPTCHA v3 site key, server-side read at build time. Inlined into
// the HTML so the Modal island (and any future captcha-protected form)
// can call grecaptcha.execute(). When the env var is unset (dev /
// forked deploys), no script is loaded and the form falls back to
// rate-limit-only protection.
const recaptchaSiteKey = process.env.RECAPTCHA_SITE_KEY ?? "";
---
<!DOCTYPE html>
<html lang={lang} class="js-scroll-ready">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={siteName} />
<meta name="theme-color" content="#0b1220" />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

<link rel="canonical" href={canonical} />
{hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
{hreflangHr && <link rel="alternate" hreflang="hr" href={hreflangHr} />}
{/* HR is the site's primary audience and the default locale — x-default
    points to it so visitors from un-mapped locales land on HR. */}
{hreflangHr && <link rel="alternate" hreflang="x-default" href={hreflangHr} />}

<meta property="og:type" content={ogType} />
<meta property="og:title" content={ogTitle ?? title} />
<meta property="og:description" content={ogDescription ?? description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={siteName} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={siteName} />
{lang === "hr" && <meta property="og:locale" content="hr_HR" />}
{lang === "hr" && <meta property="og:locale:alternate" content="en_GB" />}
{lang === "en" && <meta property="og:locale" content="en_GB" />}
{lang === "en" && <meta property="og:locale:alternate" content="hr_HR" />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={twitterTitle ?? ogTitle ?? title} />
<meta name="twitter:description" content={twitterDescription ?? ogDescription ?? description} />
<meta name="twitter:image" content={ogImage} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
{/* Preload-and-swap pattern so the Google Fonts stylesheet doesn't block
    first paint. The <noscript> link is the no-JS fallback. The font URL
    only requests the weights actually used in the design (Inter 400/500/
    600 + Playfair 400/500 + Playfair italic 400) — twelve variants used
    to ship; now five. */}
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
  onload="this.onload=null;this.rel='stylesheet'"
/>
<noscript>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
  />
</noscript>
{/* The CSS is imported from the frontmatter so Astro pipes it through
    Vite — minified, hashed, and emitted under /_astro/. */}

{/* Apply theme before paint to avoid a flash */}
<script is:inline>
  (function () {
    var t = localStorage.getItem("dp_theme") || "dark";
    document.documentElement.setAttribute("data-theme", t);
  })();
</script>

{/* reCAPTCHA v3 loader — script + stash key on window for islands.
    Only emitted when RECAPTCHA_SITE_KEY is set at build time. */}
{recaptchaSiteKey && (
  <>
    <script is:inline define:vars={{ recaptchaSiteKey }}>
      window.__dpRecaptchaSiteKey = recaptchaSiteKey;
    </script>
    <script is:inline async defer src={`https://www.google.com/recaptcha/enterprise.js?render=${recaptchaSiteKey}`}></script>
  </>
)}

{/* Restore scroll position after a language swap. Nav.astro's lang
    pills stash window.scrollY in sessionStorage on click; this runs
    in <head> on the new locale's page, disables the browser's default
    scroll-restoration, and applies the saved Y as soon as the body
    has content. Tries on DOMContentLoaded + load to win against
    layout shifts from late-mounted React islands. */}
<script is:inline>
  (function () {
    var raw;
    try { raw = sessionStorage.getItem("dp_lang_swap_y"); } catch (_) { return; }
    if (raw === null) return;
    try { sessionStorage.removeItem("dp_lang_swap_y"); } catch (_) {}
    var y = parseFloat(raw);
    if (!Number.isFinite(y)) return;
    if ("scrollRestoration" in history) history.scrollRestoration = "manual";
    var done = false;
    function apply() {
      if (done) return;
      done = true;
      // `behavior: 'instant'` so we snap to the saved Y rather than
      // animating. Without it, html { scroll-behavior: smooth } would
      // animate this scroll AND the second pass below, leaving slow
      // devices mid-page after the swap.
      window.scrollTo({ top: y, behavior: 'instant' });
    }
    if (document.readyState !== "loading") apply();
    else document.addEventListener("DOMContentLoaded", apply, { once: true });
    addEventListener("load", function () {
      // A second pass after `load` corrects for any late layout shift
      // from font swap / React-island hydration / consent-banner mount
      // that nudged content above the saved Y.
      window.scrollTo({ top: y, behavior: 'instant' });
    }, { once: true });
  })();
</script>

{/* Analytics with Google Consent Mode v2.

    ⚠️ PRE-LAUNCH TESTING MODE — analytics granted by default.
    Visitors land with analytics/functionality on so we can capture
    real-world data before full public launch. Only users who flip the
    Marketing toggle OFF in the Configure modal drop into the
    denied-everything state. REVERT before going live to EEA traffic —
    see the prior commit history for the GDPR default-denied flow.

    Order of operations:
    1. Read stored decision FIRST so the consent default reflects any
       prior opt-out (no race between the gtag pageview and the
       revocation call).
    2. gtag consent default — granted unless stored === "denied".
    3. Load the gtag loader async — measurement ID G-Q5NYL9TVV3.
    4. Load Clarity inline unless the user explicitly denied. */}
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}

  // PRE-LAUNCH: peek at the stored decision before declaring defaults
  // so a returning denier doesn't get a granted-then-revoked pageview.
  var __dpStoredConsent = null;
  try { __dpStoredConsent = localStorage.getItem('dp_consent_v1'); } catch (e) { /* blocked */ }
  var __dpDefaultAnalytics = __dpStoredConsent === 'denied' ? 'denied' : 'granted';

  gtag('consent', 'default', {
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'analytics_storage': __dpDefaultAnalytics,
    'functionality_storage': __dpDefaultAnalytics,
    'personalization_storage': 'denied',
    'security_storage': 'granted',
    'wait_for_update': 500
  });
  gtag('js', new Date());
  gtag('config', 'G-Q5NYL9TVV3');

  window.dpLoadClarity = function () {
    if (window.clarity) return;
    (function (c, l, a, r, i, t, y) {
      c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
      t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", "wzcb52p9q4");
  };

  window.dpGrantConsent = function () {
    gtag('consent', 'update', {
      'analytics_storage': 'granted',
      'functionality_storage': 'granted'
    });
    window.dpLoadClarity();
  };

  // PRE-LAUNCH: called when the user toggles Marketing OFF in the
  // Configure modal. Revokes the gtag signals; Clarity that's already
  // loaded keeps running until the next page-load (we can't easily
  // unload it), but no new sessions start once revoked.
  window.dpRevokeMarketing = function () {
    gtag('consent', 'update', {
      'analytics_storage': 'denied',
      'functionality_storage': 'denied'
    });
  };

  // PRE-LAUNCH: load Clarity unless explicitly denied.
  if (__dpStoredConsent !== 'denied') {
    window.dpLoadClarity();
  }
</script>
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Q5NYL9TVV3"></script>

{jsonLd.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
))}
</head>
<body>
<a href="#main" class="skip-link">{lang === "hr" ? "Preskoči na sadržaj" : "Skip to content"}</a>
<Nav lang={lang} />

<main id="main">
  <slot />
</main>

<Footer lang={lang} />
<Modal lang={lang} />
<ConsentBanner lang={lang} />

<script is:inline defer src="/btn-shine.js"></script>
<script is:inline defer src="/scroll-reveal.js"></script>
</body>
</html>
