---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Modal from "../components/Modal.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import "../styles/global.css";

interface Props {
  lang: "en" | "hr";
  title: string;
  description: string;
  canonical: string; // absolute URL for this page
  hreflangEn?: string; // absolute URL for EN counterpart
  hreflangHr?: string; // absolute URL for HR counterpart
  ogType?: "website" | "article";
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string; // absolute URL
  twitterTitle?: string;
  twitterDescription?: string;
  /* Page-specific structured data, rendered as <script type="application/ld+json"> tags */
  jsonLd?: Record<string, unknown>[];
}

const {
  lang,
  title,
  description,
  canonical,
  hreflangEn,
  hreflangHr,
  ogType = "website",
  ogTitle,
  ogDescription,
  ogImage = "https://www.danijelpevec.com/og-image.png",
  twitterTitle,
  twitterDescription,
  jsonLd = [],
} = Astro.props;

const siteName = "Danijel Pevec";
---
<!DOCTYPE html>
<html lang={lang} class="js-scroll-ready">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={siteName} />
<meta name="theme-color" content="#0b1220" />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

<link rel="canonical" href={canonical} />
{hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
{hreflangHr && <link rel="alternate" hreflang="hr" href={hreflangHr} />}
{/* HR is the site's primary audience and the default locale — x-default
    points to it so visitors from un-mapped locales land on HR. */}
{hreflangHr && <link rel="alternate" hreflang="x-default" href={hreflangHr} />}

<meta property="og:type" content={ogType} />
<meta property="og:title" content={ogTitle ?? title} />
<meta property="og:description" content={ogDescription ?? description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={siteName} />
<meta property="og:image" content={ogImage} />
{lang === "hr" && <meta property="og:locale" content="hr_HR" />}
{lang === "hr" && <meta property="og:locale:alternate" content="en_GB" />}
{lang === "en" && <meta property="og:locale" content="en_GB" />}
{lang === "en" && <meta property="og:locale:alternate" content="hr_HR" />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={twitterTitle ?? ogTitle ?? title} />
<meta name="twitter:description" content={twitterDescription ?? ogDescription ?? description} />
<meta name="twitter:image" content={ogImage} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
{/* Preload-and-swap pattern so the Google Fonts stylesheet doesn't block
    first paint. The <noscript> link is the no-JS fallback. The font URL
    only requests the weights actually used in the design (Inter 400/500/
    600 + Playfair 400/500 + Playfair italic 400) — twelve variants used
    to ship; now five. */}
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
  onload="this.onload=null;this.rel='stylesheet'"
/>
<noscript>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
  />
</noscript>
{/* The CSS is imported from the frontmatter so Astro pipes it through
    Vite — minified, hashed, and emitted under /_astro/. */}

{/* Apply theme before paint to avoid a flash */}
<script is:inline>
  (function () {
    var t = localStorage.getItem("dp_theme") || "dark";
    document.documentElement.setAttribute("data-theme", t);
  })();
</script>

{/* Analytics with Google Consent Mode v2.

    Order of operations is critical:
    1. Declare gtag + set every consent signal to "denied" BEFORE the
       gtag loader fires. EEA visitors land with no cookies set; GA
       still pings in cookieless "consent mode" so we get anonymous
       traffic totals.
    2. Load the gtag loader async — measurement ID G-Q5NYL9TVV3.
    3. Read the stored consent decision (`dp_consent_v1` in
       localStorage). If "granted", flip `analytics_storage` +
       `functionality_storage` on, and inject Microsoft Clarity. If
       "denied" or unset, neither tool can drop cookies; the visitor
       sees the banner from <ConsentBanner /> on next paint.

    `wait_for_update: 500` tells gtag to hold the first beacon for up
    to 500ms while the localStorage read + consent update runs. */}
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('consent', 'default', {
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'analytics_storage': 'denied',
    'functionality_storage': 'denied',
    'personalization_storage': 'denied',
    'security_storage': 'granted',
    'wait_for_update': 500
  });
  gtag('js', new Date());
  gtag('config', 'G-Q5NYL9TVV3');

  window.dpLoadClarity = function () {
    if (window.clarity) return;
    (function (c, l, a, r, i, t, y) {
      c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
      t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", "wzcb52p9q4");
  };

  window.dpGrantConsent = function () {
    gtag('consent', 'update', {
      'analytics_storage': 'granted',
      'functionality_storage': 'granted'
    });
    window.dpLoadClarity();
  };

  try {
    if (localStorage.getItem('dp_consent_v1') === 'granted') {
      window.dpGrantConsent();
    }
  } catch (e) { /* localStorage blocked — leave consent denied */ }
</script>
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Q5NYL9TVV3"></script>

{jsonLd.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
))}
</head>
<body>
<a href="#main" class="skip-link">{lang === "hr" ? "Preskoči na sadržaj" : "Skip to content"}</a>
<Nav lang={lang} />

<main id="main">
  <slot />
</main>

<Footer lang={lang} />
<Modal lang={lang} />
<ConsentBanner lang={lang} />

<script is:inline defer src="/btn-shine.js"></script>
<script is:inline defer src="/scroll-reveal.js"></script>
</body>
</html>
