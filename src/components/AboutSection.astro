---
import { getT, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
---
<section class="about-section section-pad" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-card reveal">
        <div class="about-portrait">
          <div class="mono">DP</div>
        </div>
        <div>
          <div class="role">{t.about.role}</div>
          <div class="name" style="margin-top: 6px;">{t.about.name}</div>
        </div>
        <div class="meta-list">
          {t.about.meta.map((m) => (
            <div class="row">
              <span class="lbl">{m.lbl}</span>
              <span class="val">{m.val}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="about-text reveal">
        <p class="lead">{t.about.lead}</p>
        <p>{t.about.p1}</p>
        <p>{t.about.p2}</p>
        <p class="pull">{t.about.pull}</p>
        <p>{t.about.p3}</p>
        <p>{t.about.p4}</p>
        <p style="font-family: var(--serif); font-size: clamp(18px, 1.5vw, 22px); color: var(--ink-0); line-height: 1.4; margin-top: 16px;">
          {t.about.closing}
        </p>

        <div class="alpha-block">
          <div class="alpha-logo"></div>
          <div class="alpha-text">
            <span class="alpha-name">{t.about.alphaName}</span>
            <span class="alpha-desc">{t.about.alphaDesc}</span>
          </div>
          <a href="https://www.alphacapitalis.com" target="_blank" rel="noopener noreferrer" class="alpha-link">
            {t.about.alphaLink}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="7" y1="17" x2="17" y2="7" />
              <polyline points="7 7 17 7 17 17" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
