---
import { getT, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
---
<section class="about-section section-pad" id="about">
  <div class="container">
    <div class="section-head reveal" style="max-width: 640px; margin-bottom: 64px;">
      <div class="eyebrow">{t.about.eyebrow}</div>
    </div>

    <div class="about-grid">
      <div class="about-card reveal">
        <div class="about-portrait">
          <div class="mono">DP</div>
        </div>
        <div>
          <div class="role">{t.about.role}</div>
          <div class="name" style="margin-top: 6px;">{t.about.name}</div>
        </div>
      </div>

      <div class="about-text reveal">
        <p>{t.about.lead}</p>
        <p>{t.about.p1}</p>
        <p>{t.about.p2}</p>
        <p>{t.about.pull}</p>
        <p>{t.about.p3}</p>
        <p>{t.about.p4}</p>
        <p>{t.about.closing}</p>
      </div>
    </div>
  </div>
</section>
