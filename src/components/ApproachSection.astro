---
import { getT, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
---
<section class="section-pad" id="approach">
  <div class="container">
    <div class="two-col">
      <div class="col-left">
        <div class="section-head reveal">
          <div class="eyebrow">{t.approach.eyebrow}</div>
          <h2>{t.approach.quoteA} {t.approach.quoteAccent} {t.approach.quoteB}</h2>
          <p class="lead">{t.approach.coda}</p>
        </div>
      </div>
      <div>
        <div class="approach-grid reveal-stagger">
          {t.approach.items.map((item) => (
            <div class="approach-card reveal">
              <h3>{item}</h3>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
