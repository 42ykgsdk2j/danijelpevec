---
import { getT, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
---
<section class="section-pad" id="approach">
  <div class="container">
    <div class="section-head reveal" style="max-width: 640px;">
      <div class="eyebrow">{t.approach.eyebrow}</div>
      <h2>{t.approach.quoteA} {t.approach.quoteAccent} {t.approach.quoteB}</h2>
      <p class="lead">{t.approach.coda}</p>
    </div>
  </div>
</section>
