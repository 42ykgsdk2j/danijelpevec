---
import { getT, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
---
<section class="section-pad" id="approach">
  <div class="container">
    <div class="two-col">
      <div class="col-left">
        <div class="reveal">
          <div class="approach-quote">
            {t.approach.quoteA} <span class="accent">{t.approach.quoteAccent}</span> {t.approach.quoteB}
          </div>
        </div>
      </div>
      <div class="reveal">
        <p class="lead" style="margin-bottom: 8px;">{t.approach.lead}</p>
        <div class="approach-list reveal-stagger">
          {t.approach.items.map((item) => (
            <div class="approach-list-item reveal">
              <span>{item}</span>
            </div>
          ))}
        </div>
        <p class="approach-coda">{t.approach.coda}</p>
      </div>
    </div>
  </div>
</section>
