---
import { getT, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
---
<section class="howwework-section section-pad" id="work">
  <div class="container">
    <div class="section-head reveal" style="max-width: 780px;">
      <div class="eyebrow">{t.work.eyebrow}</div>
      <h2>{t.work.title} <span class="accent italic">{t.work.titleAccent}</span></h2>
      <p class="lead">{t.work.lead}</p>
    </div>

    <div class="services-grid reveal-stagger">
      {t.work.services.map((s, i) => (
        <div class="service-card reveal">
          <span class="num">{s.num}</span>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
          <span class="glyph">
            {i === 0 ? (
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <polygon points="14 14 14 14 10 10 14 8 14 8" transform="rotate(45 12 12)" />
                <circle cx="12" cy="12" r="0.5" fill="currentColor" />
              </svg>
            ) : i === 1 ? (
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2v20" />
                <path d="M12 7c-2 0-3 2-3 4M12 7c2 0 3 2 3 4" />
                <path d="M12 11c-3 0-5 2-5 4M12 11c3 0 5 2 5 4" />
                <path d="M12 15c-3 0-6 2-6 4M12 15c3 0 6 2 6 4" />
              </svg>
            ) : (
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 2h14" />
                <path d="M5 22h14" />
                <path d="M7 2v6c0 2 1 4 5 4s5-2 5-4V2" />
                <path d="M7 22v-6c0-2 1-4 5-4s5 2 5 4v6" />
              </svg>
            )}
          </span>
        </div>
      ))}
    </div>

    <div class="start-cta reveal">
      <div class="start-cta-text">
        {t.work.ctaText} <span class="accent">{t.work.ctaAccent}</span>
      </div>
      <button class="btn btn-primary" data-open-modal>
        {t.work.ctaBtn}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </button>
    </div>
  </div>
</section>
