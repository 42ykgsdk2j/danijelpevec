---
import { getT, url, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
const assessmentUrl = url(lang, "assessment");
---
<section class="assessment-cta-section section-pad">
  <div class="container">
    <div class="assessment-cta-box reveal">
      <h2>
        {t.assessmentCta.title} <span class="accent italic">{t.assessmentCta.titleAccent}</span>
      </h2>
      <p class="lead">{t.assessmentCta.lead}</p>
      <a class="btn btn-primary" href={assessmentUrl}>
        {t.assessmentCta.btn}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <p class="assessment-cta-note">{t.assessmentCta.note}</p>
    </div>
  </div>
</section>
