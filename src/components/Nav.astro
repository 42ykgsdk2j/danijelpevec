---
import { getT, url, counterpartUrl, type Lang } from "../lib/i18n";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getT(lang);
const altUrl = counterpartUrl(lang, Astro.url.pathname);

const root = url(lang); // "/" or "/hr/"
const insightsUrl = url(lang, "blog");
const assessmentUrl = url(lang, "assessment");

const links = [
  { href: root + "#approach", label: t.nav.approach },
  { href: root + "#who", label: t.nav.who },
  { href: root + "#work", label: t.nav.work },
  { href: insightsUrl, label: t.nav.blog },
  { href: assessmentUrl, label: t.nav.assessment },
  { href: root + "#about", label: t.nav.about },
];
---
<header class="nav scrolled" role="banner" data-lang={lang}>
  <nav class="nav-inner-wrap" aria-label={lang === "hr" ? "Glavna navigacija" : "Main navigation"}>
  <div class="container nav-inner">
    <a href={root} class="brand" aria-label="Danijel Pevec">
      <div class="brand-mono">DP</div>
      <div class="brand-text">
        <div class="brand-name">Danijel Pevec</div>
        <div class="brand-tag">{t.brand.tag}</div>
      </div>
    </a>
    <div class="nav-links">
      {links.map((l) => (
        <a href={l.href} class="nav-link" data-anchor-link={l.href.includes("#") ? "" : null}>
          <span>{l.label}</span>
        </a>
      ))}
    </div>
    <div class="nav-actions">
      <div class="toggle-group" role="group" aria-label="Language">
        {lang === "en"
          ? (
            <span class="en-btn active" aria-current="page" title="English (current)">EN</span>
          )
          : (
            <a href={altUrl} class="en-btn" title="Switch to English">EN</a>
          )
        }
        {lang === "hr"
          ? (
            <span class="hr-btn active" aria-current="page" title="Hrvatski (trenutno)">HR</span>
          )
          : (
            <a href={altUrl} class="hr-btn" title="Prebaci na hrvatski">HR</a>
          )
        }
      </div>
      <button class="theme-toggle" data-theme-toggle aria-label="Toggle theme">
        <span data-theme-icon="dark">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </span>
        <span data-theme-icon="light" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
        </span>
      </button>
      <button class="btn btn-primary nav-cta" data-open-modal>{t.nav.cta}</button>
      <button class="menu-btn" data-open-drawer aria-label="Menu" aria-expanded="false" aria-controls="mobile-drawer">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
  </nav>
</header>

<div class="scrim" data-scrim></div>
<aside id="mobile-drawer" class="mobile-drawer" data-drawer role="dialog" aria-modal="true" aria-label={t.nav.cta} hidden>
  <button class="drawer-close" style="position: absolute; top: 24px; right: 24px;" data-close-drawer aria-label={lang === "hr" ? "Zatvori izbornik" : "Close menu"}>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>
  <div class="mobile-drawer-controls">
    <div class="toggle-group mobile-lang" role="group" aria-label="Language">
      {lang === "en"
        ? (<span class="active" aria-current="page" title="English (current)">EN</span>)
        : (<a href={altUrl} title="Switch to English">EN</a>)
      }
      {lang === "hr"
        ? (<span class="active" aria-current="page" title="Hrvatski (trenutno)">HR</span>)
        : (<a href={altUrl} title="Prebaci na hrvatski">HR</a>)
      }
    </div>
    <button class="theme-toggle" data-theme-toggle aria-label="Toggle theme">
      <span data-theme-icon="dark">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </span>
      <span data-theme-icon="light" style="display:none">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
      </span>
    </button>
  </div>
  {links.map((l) => (
    <a href={l.href} class="nav-link">
      <span>{l.label}</span>
    </a>
  ))}
  <button class="btn btn-primary mobile-drawer-cta" data-open-modal>
    {t.nav.cta}
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  </button>
</aside>

<script is:inline>
  (function () {
    // Drawer open/close
    var drawer = document.querySelector("[data-drawer]");
    var scrim = document.querySelector("[data-scrim]");
    var openers = document.querySelectorAll("[data-open-drawer]");
    var closers = document.querySelectorAll("[data-close-drawer]");
    // Element that had focus when the drawer opened — we restore focus here on close.
    var triggerEl = null;
    var setOpen = function (open) {
      if (open) {
        triggerEl = document.activeElement;
        drawer.hidden = false;
        drawer.classList.add("open");
        scrim.classList.add("show");
        document.body.style.overflow = "hidden";
        openers.forEach(function (b) { b.setAttribute("aria-expanded", "true"); });
        // Move focus into the drawer so keyboard users land there.
        var closeBtn = drawer.querySelector("[data-close-drawer]");
        if (closeBtn) setTimeout(function () { closeBtn.focus(); }, 50);
      } else {
        drawer.classList.remove("open");
        scrim.classList.remove("show");
        document.body.style.overflow = "";
        openers.forEach(function (b) { b.setAttribute("aria-expanded", "false"); });
        // Hide from AT once the close transition completes (matches the .open class CSS).
        setTimeout(function () { if (!drawer.classList.contains("open")) drawer.hidden = true; }, 320);
        if (triggerEl && typeof triggerEl.focus === "function") {
          setTimeout(function () { triggerEl.focus(); }, 50);
        }
      }
    };
    openers.forEach(function (b) { b.addEventListener("click", function () { setOpen(true); }); });
    closers.forEach(function (b) { b.addEventListener("click", function () { setOpen(false); }); });
    if (scrim) scrim.addEventListener("click", function () { setOpen(false); });
    drawer.querySelectorAll("a.nav-link").forEach(function (a) {
      a.addEventListener("click", function () { setOpen(false); });
    });

    // Esc closes the drawer when it's open. Also traps Tab focus inside the
    // drawer so keyboard users don't fall through to the page beneath.
    document.addEventListener("keydown", function (e) {
      if (!drawer.classList.contains("open")) return;
      if (e.key === "Escape") {
        e.preventDefault();
        setOpen(false);
        return;
      }
      if (e.key !== "Tab") return;
      var focusables = drawer.querySelectorAll(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      );
      if (focusables.length === 0) return;
      var first = focusables[0];
      var last = focusables[focusables.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    // Smooth-scroll for same-page anchor links
    document.querySelectorAll('a.nav-link[href*="#"]').forEach(function (a) {
      a.addEventListener("click", function (e) {
        var href = a.getAttribute("href");
        // If the link target is a same-document anchor (starts with current path + #
        // or just "#"), smooth-scroll instead of jumping.
        var hashIdx = href.indexOf("#");
        if (hashIdx < 0) return;
        var pathPart = href.slice(0, hashIdx);
        var hash = href.slice(hashIdx);
        var samePage = pathPart === "" || pathPart === window.location.pathname || pathPart + "/" === window.location.pathname || pathPart === window.location.pathname.replace(/\/$/, "");
        if (!samePage) return;
        var el = document.querySelector(hash);
        if (!el) return;
        e.preventDefault();
        window.scrollTo({ top: el.offsetTop - 80, behavior: "smooth" });
      });
    });

    // Theme toggle — there are two instances now (one in the nav row
    // for desktop, one inside the mobile drawer). Wire both buttons +
    // sync every icon span.
    var themeBtns = document.querySelectorAll("[data-theme-toggle]");
    var iconDarks = document.querySelectorAll('[data-theme-icon="dark"]');
    var iconLights = document.querySelectorAll('[data-theme-icon="light"]');
    function syncTheme() {
      var t = document.documentElement.getAttribute("data-theme") || "dark";
      iconDarks.forEach(function (el) { el.style.display = t === "dark" ? "" : "none"; });
      iconLights.forEach(function (el) { el.style.display = t === "light" ? "" : "none"; });
    }
    syncTheme();
    themeBtns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var cur = document.documentElement.getAttribute("data-theme") || "dark";
        var next = cur === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem("dp_theme", next);
        syncTheme();
      });
    });
  })();
</script>
