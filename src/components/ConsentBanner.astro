---
/**
 * Consent banner + Configure modal.
 *
 * Top level (banner): one-line message, "Configure" text button, "Accept"
 * gold button. The banner is shown when `localStorage.dp_consent_v1` is
 * unset.
 *
 * Configure modal: two category rows — "Required" (toggle disabled, always
 * on) and "Marketing" (toggle on by default; user can flip off). Single
 * "Save" button applies the user's selection.
 *
 * Saving behaviour:
 *   - Marketing toggle ON  → window.dpGrantConsent() — gtag analytics_
 *     storage + functionality_storage flip to granted, Clarity loads.
 *   - Marketing toggle OFF → no consent update; Consent Mode stays denied.
 *   - Either way → localStorage.dp_consent_v1 stores "granted" or
 *     "denied" so the banner doesn't re-appear next visit.
 *
 * Accept (top-level) is equivalent to Configure → Save with defaults
 * (Marketing on).
 */
import { getT, url, type Lang } from "../lib/i18n";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getT(lang);
const privacyHref = url(lang, "privacy");
---
<div
  id="consent-banner"
  class="consent-banner"
  role="region"
  aria-label={lang === "hr" ? "Postavke kolačića" : "Cookie preferences"}
  hidden
>
  <div class="consent-banner-inner">
    <p class="consent-banner-body">
      {t.consent.body}<a href={privacyHref}>{t.consent.privacyLink}</a>{t.consent.bodyAfterLink}
    </p>
    <div class="consent-banner-actions">
      <button
        type="button"
        class="consent-link"
        data-consent-configure
      >{t.consent.configure}</button>
      <button
        type="button"
        class="btn btn-primary consent-accept"
        data-consent-accept
      >{t.consent.accept}</button>
    </div>
  </div>
</div>

<div
  id="consent-config"
  class="consent-config-backdrop"
  role="dialog"
  aria-modal="true"
  aria-labelledby="consent-config-title"
  hidden
>
  <div class="consent-config">
    <h2 id="consent-config-title" class="consent-config-title">{t.consent.configureTitle}</h2>
    <p class="consent-config-intro">{t.consent.configureIntro}</p>

    <div class="consent-row consent-row-disabled">
      <div class="consent-row-text">
        <div class="consent-row-label">
          <strong>{t.consent.required}</strong>
          <span class="consent-row-pill">{t.consent.alwaysOn}</span>
        </div>
        <p class="consent-row-desc">{t.consent.requiredDesc}</p>
      </div>
      <span class="consent-toggle is-on is-disabled" aria-hidden="true">
        <span class="consent-toggle-thumb"></span>
      </span>
    </div>

    <div class="consent-row">
      <label class="consent-row-text" for="consent-marketing">
        <div class="consent-row-label">
          <strong>{t.consent.marketing}</strong>
          <span class="consent-row-pill consent-row-pill-rec">{t.consent.marketingRecommended}</span>
        </div>
        <p class="consent-row-desc">{t.consent.marketingDesc}</p>
      </label>
      <label class="consent-toggle is-on" for="consent-marketing">
        <input
          type="checkbox"
          id="consent-marketing"
          class="consent-toggle-input"
          data-consent-marketing
          checked
        />
        <span class="consent-toggle-thumb"></span>
      </label>
    </div>

    <div class="consent-config-actions">
      <button
        type="button"
        class="btn btn-primary"
        data-consent-save
      >{t.consent.save}</button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var banner = document.getElementById("consent-banner");
    var config = document.getElementById("consent-config");
    if (!banner || !config) return;
    var STORAGE_KEY = "dp_consent_v1";

    function getStored() {
      try { return localStorage.getItem(STORAGE_KEY); } catch (e) { return null; }
    }
    function setStored(value) {
      try { localStorage.setItem(STORAGE_KEY, value); } catch (e) { /* blocked */ }
    }

    function hideBanner() { banner.hidden = true; }
    function showBanner() { banner.hidden = false; }

    // Reflect the marketing checkbox state into the visual switch class.
    var marketingCheckbox = config.querySelector("[data-consent-marketing]");
    var marketingSwitch = marketingCheckbox ? marketingCheckbox.closest(".consent-toggle") : null;
    function syncSwitch() {
      if (!marketingSwitch || !marketingCheckbox) return;
      marketingSwitch.classList.toggle("is-on", marketingCheckbox.checked);
    }

    function openConfig() {
      // Re-sync the marketing toggle with the stored decision before
      // showing the modal so the user sees their current choice (the
      // privacy page's "Change preferences" button reuses this entry).
      if (marketingCheckbox) {
        marketingCheckbox.checked = getStored() !== "denied";
        syncSwitch();
      }
      config.hidden = false;
      document.body.classList.add("consent-config-open");
      var first = marketingCheckbox || config.querySelector("[data-consent-save]");
      if (first) setTimeout(function () { first.focus(); }, 50);
    }
    function closeConfig() {
      config.hidden = true;
      document.body.classList.remove("consent-config-open");
    }

    function grantMarketing() {
      if (typeof window.dpGrantConsent === "function") {
        window.dpGrantConsent();
      }
    }

    // Expose a global so any page (e.g. the privacy page's "Change
    // preferences" button) can re-open the configure modal at any time.
    window.dpOpenConsentConfig = openConfig;

    // First-paint: show the banner only if no choice has been recorded.
    if (!getStored()) showBanner();

    // Top-level Accept — same effect as Configure → Save with defaults.
    var acceptBtn = banner.querySelector("[data-consent-accept]");
    if (acceptBtn) {
      acceptBtn.addEventListener("click", function () {
        setStored("granted");
        grantMarketing();
        hideBanner();
      });
    }

    // Configure → open modal.
    var configureBtn = banner.querySelector("[data-consent-configure]");
    if (configureBtn) {
      configureBtn.addEventListener("click", openConfig);
    }

    // Save in modal — apply marketing toggle, persist, close everything.
    var saveBtn = config.querySelector("[data-consent-save]");
    if (saveBtn && marketingCheckbox) {
      saveBtn.addEventListener("click", function () {
        if (marketingCheckbox.checked) {
          setStored("granted");
          grantMarketing();
        } else {
          setStored("denied");
        }
        closeConfig();
        hideBanner();
      });
    }

    if (marketingCheckbox) {
      marketingCheckbox.addEventListener("change", syncSwitch);
      syncSwitch();
    }

    // Esc closes the configure modal but doesn't dismiss the underlying
    // banner — the user still has to choose explicitly.
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !config.hidden) {
        e.preventDefault();
        closeConfig();
      }
    });
  })();
</script>
