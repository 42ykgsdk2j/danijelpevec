---
import { getT, type Lang } from "../lib/i18n";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getT(lang);
---
<section class="challenges-section section-pad">
  <div class="container">
    <div class="section-head reveal" style="max-width: 640px;">
      <div class="eyebrow">{t.challenges.eyebrow}</div>
      <h2>{t.challenges.title} {t.challenges.titleAccent}</h2>
      <p class="lead">{t.challenges.lead}</p>
    </div>

    <div class="challenge-grid reveal-stagger">
      {t.challenges.items.map((item) => (
        <div class="challenge-card reveal">
          <h3>{item.text}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
